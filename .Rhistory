html_text() %>%
str_subset("^Table") %>%
str_remove("\\.csv$") %>%
str_trim() %>%
enframe(name = NULL, value = "table_name") %>%
mutate(
href = read_html(target_url) %>%
html_nodes("a[href$='.csv']") %>%
html_attr("href") %>%
paste0(base_url, .),
dataset = basename(href) %>% str_remove("\\.csv$"),
# Extract just the table number
table_no = str_extract(table_name, "\\d+"),
# Extract title by removing table prefix
title = str_remove(table_name, "^Table:?\\s*\\d+\\s*:?\\s*")
) %>%
select(table_no, title, dataset, href) %>%
mutate(across(where(is.character), str_trim))
View(table_info4)
# Alternative cleaner approach using more specific CSS selectors
table_info5 <- read_html(target_url) %>%
html_nodes("li") %>%
html_text() %>%
str_subset("^Table") %>%
str_remove("\\.csv$") %>%
str_replace("(\\d+)(?=\\D|$)(?!:)", "\\1:") %>%
enframe(name = NULL, value = "table_name") %>%
mutate(
href = read_html(target_url) %>%
html_nodes("a[href$='.csv']") %>%
html_attr("href") %>%
paste0(base_url, .),
dataset = basename(href) %>% str_remove("\\.csv$")
) %>%
separate(table_name, c("table_no", "title"), ":") %>%
select(table_no, title, dataset, href) %>%
mutate(across(where(is.character), str_trim))
