here::here()
here::here("data")
library(tidyverse)
# Process all RDS files
list.files(here::here("data"), pattern = "\\.rds$") %>%
walk(~ {
# Load dataset
dataset <- readRDS(.x)
# Extract prefix
new_name <- str_extract(.x, "^[^_]+")
# Save with new name
assign(new_name, dataset)
save(list = new_name, file = paste0(new_name, ".rda"))
# Remove original
file.remove(.x)
message("Converted ", .x, " to ", new_name, ".rda")
})
