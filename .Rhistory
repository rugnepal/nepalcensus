library(tidyverse)
# Process all RDS files
list.files(path=here::here("data"), pattern = "\\.rds$") %>%
walk(~ {
# Load dataset
dataset <- readRDS(.x)
# Extract prefix
new_name <- str_extract(.x, "^[^_]+")
# Save with new name
assign(new_name, dataset)
save(list = new_name, file = paste0(new_name, ".rda"))
# Remove original
file.remove(.x)
message("Converted ", .x, " to ", new_name, ".rda")
})
# Get all RDS files
rds_files <- list.files(path=here::here("data"), pattern = "\\.rds$")
# Extract new names
new_names <- str_extract(rds_files, "^[^_]+")
new_names
# Use walk2 to process files and new names in parallel
walk2(
rds_files,
new_names,
~ {
# Read and convert each file
dataset <- readRDS(.x)
assign(.y, dataset, envir = .GlobalEnv)
save(list = .y, file = paste0(.y, ".rda"), envir = .GlobalEnv)
message("Converted ", .x, " to ", .y, ".rda")
}
)
new_names
# Get all RDS files
rds_files <- list.files(path=here::here("data"), pattern = "\\.rds$", full.names = TRUE)
# Extract new names
new_names <- str_extract(rds_files, "^[^_]+")
# Use walk2 to process files and new names in parallel
walk2(
rds_files,
new_names,
~ {
# Read and convert each file
dataset <- readRDS(.x)
assign(.y, dataset, envir = .GlobalEnv)
save(list = .y, file = paste0(.y, ".rda"), envir = .GlobalEnv)
message("Converted ", .x, " to ", .y, ".rda")
}
)
rds_files %>% file.remove()
